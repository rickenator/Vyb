// Vyn language showcase using current runtime-safe patterns.

struct Point {
    x<Int>,
    y<Int>
}

factorial(n<Int>)<Int> -> {
    if (n <= 1) {
        return 1
    }
    return n * factorial(n - 1)
}

main()<Int> -> {
    println("=== Vyn Showcase ===")

    a<Int> = 10
    b<Int> = 3
    println("10 + 3 = " + (a + b).to_string())
    println("10 % 3 = " + (a % b).to_string())

    p<Point> = Point { x = 3, y = 4 }
    distance_sq<Int> = p.x * p.x + p.y * p.y
    println("point distance squared = " + distance_sq.to_string())

    scores<Vec<Int>> = Vec::new()
    scores.push(95)
    scores.push(82)
    scores.push(71)

    total<Int> = 0
    for (score in scores) {
        total = total + score
    }
    println("score count = " + scores.len().to_string())
    println("score total = " + total.to_string())

    grade<Int> = 1
    match (grade) {
        1 -> println("grade bucket: high")
        2 -> println("grade bucket: mid")
        ? -> println("grade bucket: low")
    }

    msg<String> = "Hello, Vyn!"
    println("message length = " + msg.len().to_string())
    println("factorial 5 = " + factorial(5).to_string())

    defer println("defer ran at scope exit")
    println("=== Done ===")
    return 0
}
