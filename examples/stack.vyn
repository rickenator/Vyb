// Stack behavior using Vec<Int> directly.

main()<Int> -> {
    stack<Vec<Int>> = Vec::new()
    stack.push(10)
    stack.push(20)
    stack.push(30)

    top<Int> = stack.get(stack.len() - 1)
    println("Stack example")
    println("size = " + stack.len().to_string())
    println("top = " + top.to_string())

    popped<Int> = stack.pop()
    println("popped = " + popped.to_string())
    println("size = " + stack.len().to_string())
    return 0
}
