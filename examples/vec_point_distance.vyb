// Vec<T> iteration with struct Point.

struct Point {
    x<Float>,
    y<Float>
}

main()<Int> -> {
    points<Vec<Point>> = Vec::new()

    points.push(Point { x = 3.0, y = 4.0 })
    points.push(Point { x = 1.0, y = 1.0 })
    points.push(Point { x = 5.0, y = 12.0 })
    points.push(Point { x = 2.0, y = 0.0 })

    println("Distance squared values")

    for (p in points) {
        distance_sq<Float> = p.x * p.x + p.y * p.y
        println(distance_sq)
    }

    println("count = " + points.len().to_string())
    return 0
}
