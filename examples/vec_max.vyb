// Finding the maximum value in Vec<Int>.

main()<Int> -> {
    numbers<Vec<Int>> = Vec::new()
    numbers.push(42)
    numbers.push(17)
    numbers.push(99)
    numbers.push(8)
    numbers.push(55)

    max<Int> = 0
    first<Bool> = true

    for (num in numbers) {
        if (first) {
            max = num
            first = false
        } else if (num > max) {
            max = num
        }
    }

    println("max = " + max.to_string())
    return 0
}
