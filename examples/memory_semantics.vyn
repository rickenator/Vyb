// Memory semantics example with unified syntax v0.4.0
// Pointer and borrowing examples

main()<Int> -> {
    x<Int> = 42;

    freedom {
        p<loc<Int>> = loc(x);
        at(p) = 42;
    }

    // Canonical borrow()/view() syntax for borrowed references
    b<their<Int>> = borrow(x);   // mutable borrow
    v<their<Int>> = view(x);     // immutable view

    return x;  // Returns 42
}