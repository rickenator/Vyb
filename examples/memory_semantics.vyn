// Memory semantics example with unified syntax v0.4.0
// Pointer and borrowing examples

main()<Int> -> {
    x<Int> = 42;
    
    unsafe {
        p<loc<Int>> = loc(x);
        at(p) = 42;
        // Test the new view and borrow operators
        b<their<Int>> = borrow x;       // Now implemented!
        v<their<Int>> = view x;         // Now implemented!
        length<Int> = (view x).len();   // This should work once String methods are added
    }
    
    return x;  // Returns 42
}