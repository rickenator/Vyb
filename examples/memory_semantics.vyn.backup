// Memory semantics example with unified syntax v0.4.0
// Pointer and borrowing examples

main()<Int> -> {
    x<Int> = 42;
    
    unsafe {
        p<loc<Int>> = loc(x);
        at(p) = 42;
        // b<their<Int>> = borrow(x);       // TODO: borrow not implemented yet
        // v<their<Int const>> = view(x);    // TODO: view not implemented yet
        // at(loc(b)) = 100;                // TODO: modify via borrow
    }
    
    return x;  // Returns 42
}