// Filtering even numbers from Vec<Int>.

main()<Int> -> {
    numbers<Vec<Int>> = Vec::new()
    numbers.push(1)
    numbers.push(2)
    numbers.push(3)
    numbers.push(4)
    numbers.push(5)
    numbers.push(6)

    evens<Vec<Int>> = Vec::new()

    for (num in numbers) {
        half<Int> = num / 2
        doubled<Int> = half * 2
        if (doubled == num) {
            evens.push(num)
        }
    }

    sum<Int> = 0
    for (even in evens) {
        sum = sum + even
    }

    println("even sum = " + sum.to_string())
    return 0
}
