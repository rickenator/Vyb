// Flat binary-search-tree storage demo.
// Node traversal helpers are kept inline to avoid Vec by-value ownership copies.

struct TreeNode {
    key<Int>,
    value<String>
}

main()<Int> -> {
    nodes<Vec<TreeNode>> = Vec::new()
    nodes.push(TreeNode { key = 50, value = "fifty" })
    nodes.push(TreeNode { key = 30, value = "thirty" })
    nodes.push(TreeNode { key = 70, value = "seventy" })
    nodes.push(TreeNode { key = 20, value = "twenty" })
    nodes.push(TreeNode { key = 40, value = "forty" })

    target<Int> = 40
    result<String> = "NOT_FOUND"

    for (node in nodes) {
        if (node.key == target) {
            result = node.value
        }
    }

    println("Flat tree example")
    println("node count = " + nodes.len().to_string())
    println("search 40 = " + result)
    return 0
}
