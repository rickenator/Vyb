# Errable Aspect - Core error type interface
#
# Any type implementing Errable can be used with fail/trap error handling.
# This aspect defines the minimum interface for error types in VyB.

aspect Errable {
    # Get human-readable error message
    message(self<Self>)<String> -> { }

    # Get numeric error code (0 = default/no specific code)
    code(self<Self>)<Int> -> { }
}
