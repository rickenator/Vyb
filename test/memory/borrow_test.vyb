// Simple test for borrow functionality
struct TestStruct {
    value<Int>
}

modify_struct(s<their<TestStruct>>)<Void> -> {
    s.value = 42
}

main()<Int> -> {
    my_struct<TestStruct> = TestStruct { value = 0 }
    println("Before: " + my_struct.value.to_string())

    modify_struct(borrow(my_struct))

    println("After: " + my_struct.value.to_string())
    return 0
}