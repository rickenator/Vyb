// @test: repr(C) struct rejects ownership fields
// @description: C ABI structs cannot contain VyB ownership-qualified fields
// @category: ffi, interop
// @expect: fail
// @semantic-only: true
// @expect-error: repr(C) struct field "owned" cannot use ownership-qualified type our<Int>
// @tags: ffi, repr-c, diagnostics

#[repr(C)]
struct CHandle {
    owned<our<Int>>
}

main()<Int> -> {
    return 0
}
