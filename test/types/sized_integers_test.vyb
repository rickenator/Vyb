// @test: Sized integer types test
// @description: Sized integer types test
// @category: types
// @expect: pass
// @expect-return: 120
# Test all sized integer types: Int8, Int16, Int32, Int64 (Int)

test_int8()<Int> -> {
    small<Int8> = 127
    negative<Int8> = -128
    zero<Int8> = 0
    return 8
}

test_int16()<Int> -> {
    medium<Int16> = 32767
    negative<Int16> = -32768
    zero<Int16> = 0
    return 16
}

test_int32()<Int> -> {
    large<Int32> = 2147483647
    negative<Int32> = -2147483647
    zero<Int32> = 0
    return 32
}

test_int64()<Int> -> {
    huge<Int> = 9223372036854775807
    negative<Int> = -9223372036854775807
    zero<Int> = 0
    return 64
}

main()<Int> -> {
    result<Int> = 0

    result = result + test_int8()
    result = result + test_int16()
    result = result + test_int32()
    result = result + test_int64()

    # Should return 8 + 16 + 32 + 64 = 120
    return result
}
