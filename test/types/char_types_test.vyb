// @test: Char and Rune types test
// @description: Char and Rune types test
// @category: types
// @expect: pass
// @expect-return: 313
# Test character types: Char (UTF-8 code unit) and Rune (Unicode code point)

test_char()<Int> -> {
    # Char represents a single UTF-8 code unit (1 byte)
    letter_a<Char> = 97    # 'a'
    letter_z<Char> = 122   # 'z'
    digit_0<Char> = 48     # '0'
    space<Char> = 32       # ' '
    newline<Char> = 10     # '\n'

    # Return the sum to verify they're all loaded
    # 97 + 122 + 48 + 32 + 10 = 309
    return 309
}

test_rune()<Int> -> {
    # Rune represents a full Unicode code point (up to 32 bits)
    ascii_a<Rune> = 97           # 'a' - basic ASCII
    emoji_smile<Rune> = 128512   # 😀 U+1F600
    kanji<Rune> = 26408          # 本 U+672C
    latin_A<Rune> = 65           # 'A'

    # Return a simple sum to verify (we can't easily add the full values)
    # Just return the count of runes defined
    return 4
}

main()<Int> -> {
    char_result<Int> = test_char()
    rune_result<Int> = test_rune()

    # 309 + 4 = 313
    return char_result + rune_result
}
