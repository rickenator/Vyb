// @test: Mutable borrow conflict rejected
// @expect: fail
// @expect-error: Cannot take mutable borrow of 'x' while it is already borrowed.
//# EXPECTED ERROR: Cannot take mutable borrow of 'x' while it is already borrowed.

main()<Int> -> {
    x<my<Int>> = my(10);

    // Conflicting borrows should fail even without freedom
    v<their<Int const>> = view(x);
    b<their<Int>> = borrow(x);

    return x;
}
