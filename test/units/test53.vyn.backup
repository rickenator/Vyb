//# EXPECTED ERROR: borrow() argument must be an owned type my<T> or our<T>

main()<Int> -> {
    x<Int> = 10; // Not an owned type (missing my<> or our<>)
    
    unsafe {
        // Using borrow on non-owned type should fail
        var<their<Int>> b = borrow(x);
        b = 20;
    }
    
    return x;
}
