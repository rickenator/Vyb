// Test to verify template constraint validation is properly triggered
// by demonstrating that invalid constraints fail and valid ones pass

// Valid: T bounded by Comparable trait
template ValidContainer<T: Comparable> {
    struct Data {
        value<T>
    }
}

// Valid: Multiple constraints using +
template ValidHashMap<K: Hashable + Equatable, V> {
    struct Entry {
        key<K>,
        value<V>
    }
}

// Valid: Numeric constraint
template ValidCalculator<T: Numeric> {
    struct Data {
        result<T>
    }
}

fn<Int> main() -> {
    // The templates have been parsed and stored with constraints
    // Constraint validation will be triggered during actual instantiation
    var<Int> test = 42;
    return test;
}