// Simple async functionality test - no await expressions for now
// Tests async function compilation and Future<T> type handling

// Basic async function returning Future<Int>
async simple_async_int()<Future<Int>> -> {
    println("Async function executing...");
    return 42;
}

// Async function returning Future<String>  
async simple_async_string()<Future<String>> -> {
    println("Async string function executing...");
    return "hello async";
}

// Async void function
async simple_async_void()<Future<Void>> -> {
    println("Async void function executing...");
    return;
}

// Regular function that creates async tasks
test_simple_async()<Void> -> {
    println("=== Simple Async Test ===");
    
    // Test basic async function calls
    future1<Future<Int>> = simple_async_int();
    println("Created Future<Int>");
    
    future2<Future<String>> = simple_async_string();
    println("Created Future<String>");
    
    future3<Future<Void>> = simple_async_void();
    println("Created Future<Void>");
    
    println("All async functions called successfully");
}

main()<Void> -> {
    println("Starting simple async test");
    
    test_simple_async();
    
    println("Simple async test completed");
    return;
}