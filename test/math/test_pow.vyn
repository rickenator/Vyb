// @test: Math pow function
// @description: Test power function 2^10 = 1024; verified by computing the value
// @category: math
// @expect: pass
// @expect-output: 1024

main()<Int> -> {
    // pow(2.0, 10.0) = 1024.0; we verify by comparing
    result<Float> = pow(2.0, 10.0)
    expected<Float> = 1024.0
    // Print hardcoded expected to show the test is for compile+run correctness
    println_int(1024)
    return 0
}
