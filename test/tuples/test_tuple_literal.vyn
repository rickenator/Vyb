// Test tuple literals - direct creation with (val1, val2, val3) syntax

main()<Int> -> {
    # Test 1: Simple tuple literal
    data<Tuple<Int, Int, Int>> = (10, 20, 30)
    x<Int> = data[0]
    y<Int> = data[1]
    z<Int> = data[2]
    if (x != 10) { return 1 }
    if (y != 20) { return 2 }
    if (z != 30) { return 3 }
    
    # Test 2: Mixed type tuple literal  
    mixed<Tuple<Int, String, Bool>> = (42, "hello", true)
    num<Int> = mixed[0]
    text<String> = mixed[1]
    flag<Bool> = mixed[2]
    if (num != 42) { return 4 }
    if (flag != true) { return 5 }
    
    # Test 3: Tuple len() works with literals
    size<Int> = data.len()
    if (size != 3) { return 6 }
    
    # Test 4: Single element tuple (requires trailing comma)
    single<Tuple<Int>> = (99,)
    val<Int> = single[0]
    if (val != 99) { return 7 }
    
    # Test 5: Pair tuple
    pair<Tuple<Int, Int>> = (100, 200)
    a<Int> = pair[0]
    b<Int> = pair[1]
    sum<Int> = a + b
    if (sum != 300) { return 8 }
    
    return 0  # All tests passed!
}
