// Test tuple element access using [index] syntax

get_triple()<Tuple<Int, Int, Int>> -> {
    return 10, 20, 30
}

get_mixed()<Tuple<Int, String, Bool, Float>> -> {
    return 42, "hello", true, 3.14
}

get_pair()<Tuple<Int, Int>> -> {
    return 1, 2
}

get_quad()<Tuple<Int, Int, Int, Int>> -> {
    return 1, 2, 3, 4
}

get_single()<Tuple<Int>> -> {
    return 99
}

test_tuple_index_basic()<Int> -> {
    data<Tuple<Int, Int, Int>> = get_triple()

    x<Int> = data[0]
    y<Int> = data[1]
    z<Int> = data[2]

    if (x != 10) { return 1 }
    if (y != 20) { return 2 }
    if (z != 30) { return 3 }

    return 0
}

test_tuple_index_mixed_types()<Int> -> {
    data<Tuple<Int, String, Bool, Float>> = get_mixed()

    num<Int> = data[0]
    str<String> = data[1]
    flag<Bool> = data[2]
    pi<Float> = data[3]

    if (num != 42) { return 1 }
    if (flag != true) { return 2 }

    return 0
}

test_tuple_len()<Int> -> {
    pair<Tuple<Int, Int>> = get_pair()
    triple<Tuple<Int, Int, Int>> = get_triple()
    quad<Tuple<Int, Int, Int, Int>> = get_quad()

    len2<Int> = pair.len()
    len3<Int> = triple.len()
    len4<Int> = quad.len()

    if (len2 != 2) { return 1 }
    if (len3 != 3) { return 2 }
    if (len4 != 4) { return 3 }

    return 0
}

test_tuple_index_in_expression()<Int> -> {
    values<Tuple<Int, Int, Int>> = get_triple()

    # Use tuple elements in calculations
    sum<Int> = values[0] + values[1] + values[2]

    if (sum != 30) { return 1 }

    return 0
}

test_single_element_tuple()<Int> -> {
    single<Tuple<Int>> = get_single()

    value<Int> = single[0]
    length<Int> = single.len()

    if (value != 99) { return 1 }
    if (length != 1) { return 2 }

    return 0
}

main()<Int> -> {
    result1<Int> = test_tuple_index_basic()
    if (result1 != 0) { return 10 + result1 }

    result2<Int> = test_tuple_index_mixed_types()
    if (result2 != 0) { return 20 + result2 }

    result3<Int> = test_tuple_len()
    if (result3 != 0) { return 30 + result3 }

    result4<Int> = test_tuple_index_in_expression()
    if (result4 != 0) { return 40 + result4 }

    result5<Int> = test_single_element_tuple()
    if (result5 != 0) { return 50 + result5 }

    return 0  # All tests passed
}
