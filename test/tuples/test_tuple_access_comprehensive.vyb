// Comprehensive test of tuple indexing and len() functionality

get_data()<Tuple<Int, String, Bool, Float>> -> {
    return 100, "test", true, 2.5
}

get_numbers()<Tuple<Int, Int, Int, Int, Int>> -> {
    return 1, 2, 3, 4, 5
}

process_tuple(data<Tuple<Int, Int, Int>>)<Int> -> {
    # Access elements and compute sum
    a<Int> = data[0]
    b<Int> = data[1]
    c<Int> = data[2]
    return a + b + c
}

main()<Int> -> {
    # Test 1: Mixed type tuple indexing
    mixed<Tuple<Int, String, Bool, Float>> = get_data()
    num<Int> = mixed[0]
    text<String> = mixed[1]
    flag<Bool> = mixed[2]
    fval<Float> = mixed[3]

    if (num != 100) { return 1 }
    if (flag != true) { return 2 }

    # Test 2: Tuple length
    len<Int> = mixed.len()
    if (len != 4) { return 3 }

    # Test 3: Large tuple
    numbers<Tuple<Int, Int, Int, Int, Int>> = get_numbers()
    size<Int> = numbers.len()
    if (size != 5) { return 4 }

    # Test 4: Arithmetic with tuple elements
    sum<Int> = numbers[0] + numbers[1] + numbers[2] + numbers[3] + numbers[4]
    if (sum != 15) { return 5 }

    # Test 5: Passing tuple to function
    triple<Tuple<Int, Int, Int>> = (10, 20, 30)  # This won't parse yet
    # result<Int> = process_tuple(triple)

    return 0  # All tests passed
}
