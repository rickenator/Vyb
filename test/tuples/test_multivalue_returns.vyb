// Test multi-value returns are tuples

get_pair()<Int, Int> -> {
    return 10, 20
}

get_triple()<Int, String, Bool> -> {
    return 42, "test", true
}

get_five()<Int, Int, Int, Int, Int> -> {
    return 1, 2, 3, 4, 5
}

main()<Int> -> {
    # Test 1: Inline syntax multi-value return is a tuple
    result1<Tuple<Int, Int>> = get_pair()
    x<Int> = result1[0]
    y<Int> = result1[1]
    if (x != 10) { return 1 }
    if (y != 20) { return 2 }

    # Test 2: Inline return syntax should be equivalent to Tuple<>
    result2<Int, String, Bool> = get_triple()
    num<Int> = result2[0]
    text<String> = result2[1]
    flag<Bool> = result2[2]
    if (num != 42) { return 3 }
    if (flag != true) { return 4 }

    # Test 3: Both inline and Tuple<> syntax should be interchangeable
    result3<Tuple<Int, Int, Int, Int, Int>> = get_five()
    len<Int> = result3.len()
    if (len != 5) { return 5 }

    # Test 4: Can use tuple methods on multi-value returns
    pair_len<Int> = result1.len()
    if (pair_len != 2) { return 6 }

    return 0
}
