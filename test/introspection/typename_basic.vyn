// @test: typename basic
// @description: typename(expr) returns the type name as a String
// @category: introspection
// @expect: pass
// @expect-output: typename works

main()<Int> -> {
    x<Int> = 42
    y<Float> = 3.14
    s<String> = "hello"
    name_x<String> = typename(x)
    name_y<String> = typename(y)
    println("typename works")
    return 0
}
