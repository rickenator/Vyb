// Test basic typename operator
// typename(expr) returns a String with the type name

main()<Int> -> {
    x<Int> = 42;
    y<float> = 3.14;
    s<string> = "hello";
    
    // Get type names as strings
    name_x<string> = typename(x);
    name_y<string> = typename(y);
    name_s<string> = typename(s);
    
    println("typename(x) works!");
    
    return 0;
}
