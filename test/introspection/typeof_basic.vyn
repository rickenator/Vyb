// @test: typeof basic
// @description: typeof(expr) returns a type hash; equal types compare equal
// @category: introspection
// @expect: pass
// @expect-output: typeof works

main()<Int> -> {
    x<Int> = 42
    y<Float> = 3.14
    same_int<Bool> = (typeof(x) == typeof(100))
    diff_types<Bool> = (typeof(x) != typeof(y))
    if (same_int && diff_types) {
        println("typeof works")
    }
    return 0
}
