// @test: typeof expressions
// @description: typeof works on arithmetic expressions and integer literals
// @category: introspection
// @expect: pass
// @expect-output: expr match

main()<Int> -> {
    x<Int> = 10
    expr_match<Bool> = (typeof(x + 5) == typeof(x * 2))
    if (expr_match) {
        println("expr match")
    }
    return 0
}
