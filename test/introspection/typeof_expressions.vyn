// Test typeof with expressions and literals

main()<Int> -> {
    // typeof on expressions - compare types
    x<Int> = 10;
    expr_match<Bool> = (typeof(x + 5) == typeof(x * 2));
    
    // typeof on function calls
    func_match<Bool> = (typeof(get_number()) == typeof(42));
    
    println("typeof on expressions works!");
    
    return 0;
}

get_number()<Int> -> {
    return 42;
}
