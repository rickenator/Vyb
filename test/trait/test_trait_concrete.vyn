# Test concrete trait implementation without generics
# Define a simple struct and implement a trait for it

trait Container {
    size(self<Self>)<Int> -> { }
    is_empty(self<Self>)<Bool> -> { }
}

struct IntBox {
    value<Int>
}

# Concrete impl - no generics
impl Container for IntBox {
    size(self<IntBox>)<Int> -> {
        return 1  # Always contains 1 element
    }
    
    is_empty(self<IntBox>)<Bool> -> {
        return false  # Never empty if it exists
    }
}

main()<Int> -> {
    box<IntBox> = IntBox { value = 42 }
    
    # Call trait methods
    s<Int> = box.size()
    
    return s  # Should return 1
}
