# Test generic struct with concrete type usage
# This should trigger monomorphization

struct Box<T> {
    value<T>
}

# Function that creates Box<Int>
make_int_box(val<Int>)<Box<Int>> -> {
    # Create Box value directly without type annotation
    return { value = val }
}

main()<Int> -> {
    # Use Box with concrete type Int
    b<Box<Int>> = make_int_box(42)
    return 0
}
