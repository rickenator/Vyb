# Vec type definition for testing
# Simple non-generic version first to validate trait impls work

struct Vec {
    data<loc<Int>>,     # Pointer to data
    length<Int>,         # Current number of elements
    capacity<Int>        # Allocated capacity
}

# Constructor
new_vec()<Vec> -> {
    v<Vec> = Vec {
        data = loc(0),
        length = 0,
        capacity = 0
    }
    return v
}

# Basic methods
vec_len(v<Vec>)<Int> -> {
    return v.length
}

vec_is_empty(v<Vec>)<Bool> -> {
    return v.length == 0
}

# Test the Vec type
main()<Int> -> {
    v<Vec> = new_vec()
    
    len<Int> = vec_len(v)
    empty<Bool> = vec_is_empty(v)
    
    return len
}
