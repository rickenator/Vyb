// Phase 3 (simplified): Trait implementation for concrete Vec type
// Tests impl Trait for Vec<Int> (concrete generic type)

trait Container {
    size(self<Self>)<Int> -> { }
    is_empty(self<Self>)<Bool> -> { }
}

// Concrete impl: Vec<Int> implements Container
impl Container for Vec<Int> {
    size(self<Vec<Int>>)<Int> -> {
        return self.len()
    }
    
    is_empty(self<Vec<Int>>)<Bool> -> {
        return self.len() == 0
    }
}

main()<Int> -> {
    // Create a Vec<Int>
    numbers<Vec<Int>> = Vec::new()
    numbers.push(1)
    numbers.push(2)
    numbers.push(3)
    
    // Call trait methods on Vec<Int>
    size<Int> = numbers.size()
    
    // Should return 3
    return size
}
