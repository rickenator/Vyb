# Simple test to trigger aspect method monomorphization detection
# We'll add actual method calls in the next iteration

struct Box<T> {
    value<T>
}

aspect Display {
    show(self<Self>)<String> -> { }
}

bind<T> Display -> Box<T> {
    show(self<Self>)<String> -> {
        return "Box"
    }
}

main()<Int> -> {
    # Create Box<Int> - this should monomorphize Box struct
    b<Box<Int>> = Box<Int> { value = 42 }
    
    # TODO: Once method call detection is added:
    # str<String> = b.show()  # This will trigger monomorphization
    
    return 0
}
