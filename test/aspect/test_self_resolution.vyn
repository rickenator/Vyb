# Test Self type resolution in generic aspect implementations
# Phase 6 Step 1: Verify Self resolves to Box<T> in bind<T> Trait -> Box<T>

struct Box<T> {
    value<T>
}

aspect Display {
    show(self<Self>)<String> -> { }
}

# Generic implementation: Self should resolve to Box<T>
bind<T> Display -> Box<T> {
    show(self<Self>)<String> -> {
        return "Box"
    }
}

main()<Int> -> {
    # Just test that it parses and semantic analysis succeeds
    return 0
}
