// Phase 2: Simple aspect implementation test without println
// Tests bind Trait -> Type with method returning values
// @expect-return: 25

aspect Calculator {
    add(self<Self>, value<Int>)<Int> -> { }
    get_value(self<Self>)<Int> -> { }
}

struct Counter {
    count<Int>
}

bind Calculator -> Counter {
    add(self<Counter>, value<Int>)<Int> -> {
        return self.count + value
    }
    
    get_value(self<Counter>)<Int> -> {
        return self.count
    }
}

main()<Int> -> {
    c<Counter> = Counter { count = 10 }
    
    // Call aspect methods
    result<Int> = c.add(5)
    value<Int> = c.get_value()
    
    return result + value  // Should return 15 + 10 = 25
}
