// @test: aspect bounds on generic parameters
// @description: Bounds let generic code call aspect methods guaranteed by the bound
// @category: aspect, bounds
// @expect: pass
// @semantic-only: true

aspect Display {
    show(self)<Void>
}

aspect Clone {
    clone(self)<Self>
}

struct Point {
    x<Int>,
    y<Int>
}

struct Box<T> {
    value<T>
}

bind Display -> Point {
    show(self)<Void> -> {
        return
    }
}

bind Clone -> Point {
    clone(self)<Self> -> {
        result<Point> = Point { x = self.x, y = self.y }
        return result
    }
}

bind<T<Display>> Display -> Box<T> {
    show(self)<Void> -> {
        self.value.show()
        return
    }
}

bind<T<Display, Clone>> Clone -> Box<T> {
    clone(self)<Self> -> {
        self.value.show()
        self.value.clone()
        return self
    }
}

printItem<T<Display>>(item<T>)<Void> -> {
    item.show()
    return
}

useDisplayAndClone<T<Display, Clone>>(item<T>)<Void> -> {
    item.show()
    item.clone()
    return
}

main()<Int> -> {
    return 0
}
