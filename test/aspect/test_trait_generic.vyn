// Phase 3: Generic aspect implementations
// Tests bind<T> Trait -> GenericType<T>

aspect Container {
    size(self<Self>)<Int> -> { }
    is_empty(self<Self>)<Bool> -> { }
}

// Generic bind: any Vec<T> implements Container
bind<T> Container -> Vec<T> {
    size(self<Vec<T>>)<Int> -> {
        return self.len()
    }
    
    is_empty(self<Vec<T>>)<Bool> -> {
        return self.len() == 0
    }
}

main()<Int> -> {
    // Create a Vec<Int>
    numbers<Vec<Int>> = Vec::new()
    numbers.push(1)
    numbers.push(2)
    numbers.push(3)
    
    // Call aspect methods on Vec<Int>
    size<Int> = numbers.size()
    empty<Bool> = numbers.is_empty()
    
    // Should return 3 (size is 3, empty is 0/false)
    return size
}
