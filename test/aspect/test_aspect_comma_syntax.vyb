// Test comma-separated aspect method declarations

aspect Display {
    show(self<Self>)<Void>,
    format(self<Self>)<String>,
}

struct Box<T> {
    value<T>
}

bind<T> Display -> Box<T> {
    show(self<Self>)<Void> -> {
        println("Box contains a value")
    },

    format(self<Self>)<String> -> {
        "formatted"
    },
}

main()<Int> -> {
    box<Box<Int>> = Box<Int> { value: 42 }
    box.show()
    println("Test passed!")
    0
}
