// @test: aspect receiver bare self basic
// @description: Simple aspect receivers may use canonical bare self syntax
// @category: aspect, receiver
// @expect: pass

aspect Greet {
    greet(self)<Void>
}

struct Person {
    name<String>
}

bind Greet -> Person {
    greet(self)<Void> -> {
        return
    }
}

main()<Int> -> {
    p<Person> = Person { name = "VyB" }
    p.greet()
    return 0
}
