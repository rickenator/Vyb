// Test: Multiple aspects per type
// A type can implement multiple aspects

aspect Display {
    show(self<Self>)<Void>
}

aspect Debug {
    debug(self<Self>)<Void>
}

aspect Clone {
    clone(self<Self>)<Self>
}

struct Point {
    x<Int>,
    y<Int>
}

// Implement Display for Point
bind Display -> Point {
    show(self<Self>)<Void> -> {
        println("Point(x, y)");
    }
}

// Implement Debug for Point
bind Debug -> Point {
    debug(self<Self>)<Void> -> {
        println("Point { x: ..., y: ... }");
    }
}

// Implement Clone for Point
bind Clone -> Point {
    clone(self<Self>)<Self> -> {
        result<Point> = Point { x = self.x, y = self.y };
        return result;
    }
}

main()<Int> -> {
    p<Point> = Point { x = 10, y = 20 };

    // Call methods from different aspects
    p.show();      // Display aspect
    p.debug();     // Debug aspect
    p2<Point> = p.clone();  // Clone aspect

    p2.show();

    println("Multiple aspects test passed!");
    return 0;
}
