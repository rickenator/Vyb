# Test method call on monomorphized generic type with aspect bind
# This should trigger method monomorphization

struct Box<T> {
    value<T>
}

aspect Display {
    show(self<Self>)<String> -> { }
}

bind<T> Display -> Box<T> {
    show(self<Self>)<String> -> {
        return "Box"
    }
}

main()<Int> -> {
    # Create Box<Int> - this monomorphizes Box
    b<Box<Int>> = Box<Int> { value = 42 }
    
