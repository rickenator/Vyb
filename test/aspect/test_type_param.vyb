// @test: type parameter recognition in generic bind methods
// @description: Generic bind method bodies may declare locals using the bind type parameter
// @category: aspect, generics
// @expect: pass
// @semantic-only: true

aspect Container {
    size(self)<Int>
}

struct Wrapper<T> {
    data<T>
}

bind<T> Container -> Wrapper<T> {
    size(self)<Int> -> {
        value<T> = self.data
        return 1
    }
}

main()<Int> -> {
    return 0
}
