# Test type parameter recognition in generic bind methods

aspect Container {
    size(self<Self>)<Int> -> { }
}

# Generic bind with type parameter T
bind<T> Container -> Wrapper<T> {
    size(self<Wrapper<T>>)<Int> -> {
        # Use T in a local variable declaration
        value<T> = self.data
        return 1
    }
}

main()<Int> -> {
    return 0
}
