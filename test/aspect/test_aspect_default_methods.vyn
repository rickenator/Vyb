// Test: Default method implementations in aspects
// Tests optional methods with default implementations

aspect Greet {
    hello(self<Self>)<Void> -> {
        println("Hello from default!");
    }
    
    goodbye(self<Self>)<Void>  // Mandatory - no default
}

struct Person {
    name<String>
}

struct Robot {
    id<Int>
}

// Person uses default hello, implements goodbye
bind Greet -> Person {
    goodbye(self<Self>)<Void> -> {
        println("Person says goodbye");
    }
}

// Robot overrides hello, implements goodbye
bind Greet -> Robot {
    hello(self<Self>)<Void> -> {
        println("Robot says hello");
    }
    
    goodbye(self<Self>)<Void> -> {
        println("Robot says goodbye");
    }
}

main()<Int> -> {
    person<Person> = Person { name = "Alice" };
    robot<Robot> = Robot { id = 42 };
    
    person.hello();     // Should print "Hello from default!"
    person.goodbye();   // Should print "Person says goodbye"
    
    robot.hello();      // Should print "Robot says hello"
    robot.goodbye();    // Should print "Robot says goodbye"
    
    println("All tests passed!");
    return 0;
}
