# Test 10: Untrapped error - should invoke runtime handler
# Tests that untrapped errors are caught by the runtime and reported

risky_operation()<Int> -> {
    fail UnhandledError { message = "This error has no trap!" }
    return 0
}

main()<Int> -> {
    # This will fail and there's no trap to catch it
    # Runtime should catch it and report:
    # - Error type and values
    # - Stack trace
    # - Exit with code 1
    risky_operation()
    
    # Should never reach here
    println("This should not print")
    return 0
}
