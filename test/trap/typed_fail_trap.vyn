// @test: Typed fail caught by typed trap
// @description: fail<T>(value) carries an explicit error type for trap dispatch
// @category: trap, errors
// @expect: pass
// @expect-output: -1
// @tags: fail, trap, typed

main()<Int> -> {
    {
        fail<Int>(42)
    } trap (e<Int>) -> {
        println_int(-1)
    }
    return 0
}
