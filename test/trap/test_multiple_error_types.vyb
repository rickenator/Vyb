// @expect-return: 141
# Test multiple error types (Phase 6.2)
# Function can fail with different error types, trap clauses match specific types

struct ErrorA {
    code<Int>
}

struct ErrorB {
    value<Int>
}

test_error(n<Int>)<Int> -> {
    if (n == 1) {
        fail ErrorA { code = 42 }
    }
    if (n == 2) {
        fail ErrorB { value = 99 }
    }
    return n * 10
}

main()<Int> -> {
    r1<Int> = {
        test_error(1)
    } trap (e<ErrorA>) -> {
        e.code  # Returns 42
    } trap (e<ErrorB>) -> {
        e.value  # Won't match
    }

    r2<Int> = {
        test_error(2)
    } trap (e<ErrorA>) -> {
        1  # Won't match
    } trap (e<ErrorB>) -> {
        e.value  # Returns 99
    }

    # Should return 42 + 99 = 141
    return r1 + r2
}
