# Simple fail/trap test with integer error type

divide(a<Int>, b<Int>)<Int> -> {
    if (b == 0) {
        fail 42  # Simple integer error code
    }
    return a / b
}

main()<Int> -> {
    result<Int> = {
        divide(10, 0)
    } trap (e<Int>) -> {
        # Caught the error
        return -1
    }
    
    return result
}
