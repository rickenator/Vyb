// Phase 6.5: Simple wildcard trap test - direct return

risky_operation()<Int> -> {
    fail "Something went wrong"
}

main()<Int> -> {
    value<Int> = {
        risky_operation()
    } trap (e<?>) -> {
        println("Caught wildcard error!")
        return 99
    }
    
    println("This should not print")
    return value
}
