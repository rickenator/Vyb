# Test 08: Fail in function with trap at call site
# Tests error propagation from function calls

divide(a<Int>, b<Int>)<Int> -> {
    if (b == 0) {
        fail DivisionByZero { dividend = a, divisor = b }
    }
    return a / b
}

safe_divide(a<Int>, b<Int>)<Int> -> {
    result<Int> = {
        divide(a, b)
    } trap (e<DivisionByZero>) -> {
        println("Cannot divide " + e.dividend.to_string() + " by zero")
        return -1
    }
    return result
}

main()<Int> -> {
    result1<Int> = safe_divide(10, 2)
    result2<Int> = safe_divide(10, 0)
    
    println("Results: " + result1.to_string() + ", " + result2.to_string())
    return 0
}
