# Test 16: Error type hierarchy - composition-based
# Tests error hierarchy using composition pattern

# Base error type
struct Error {
    message<String>,
    location<SourceLocation>,
    timestamp<Int64>
}

# IO error extends Error
struct IOError {
    base<Error>,
    path<String>
}

# FileNotFound extends IOError
struct FileNotFound {
    base<IOError>,
    attempted_paths<Vec<String>>
}

open_file(path<String>)<File> -> {
    if (!file_exists(path)) {
        fail FileNotFound {
            base = IOError {
                base = Error {
                    message = "File not found",
                    location = here(),
                    timestamp = now()
                },
                path = path
            },
            attempted_paths = vec![path, path + ".txt", "/tmp/" + path]
        }
    }
    return File.open(path)
}

main()<Int> -> {
    # Catch specific error
    {
        open_file("missing.txt")
    } trap (e<FileNotFound>) -> {
        println("File not found, tried " + e.attempted_paths.len().to_string() + " paths")
        println("Path was: " + e.base.path)
    }

    # Catch broader error type
    {
        open_file("another_missing.txt")
    } trap (e<IOError>) -> {
        println("IO error at path: " + e.path)
        println("Message: " + e.base.message)
    }

    # Catch base error type
    {
        open_file("yet_another.txt")
    } trap (e<Error>) -> {
        println("Generic error: " + e.message)
    }

    return 0
}
