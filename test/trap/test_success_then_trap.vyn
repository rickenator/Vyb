# Test success then trap
divide(a<Int>, b<Int>)<Int> -> {
    if (b == 0) {
        fail 42
    }
    return a / b
}

compute(x<Int>, y<Int>)<Int> -> {
    result<Int> = divide(x, y)
    return result + 10
}

main()<Int> -> {
    val1<Int> = compute(10, 2)   # Success - should return 15
    val2<Int> = {
        compute(10, 0)            # Error - trap should catch and return -1
    } trap (e<Int>) -> {
        return -1
    }
    return val1 + val2           # 15 + (-1) = 14
}
