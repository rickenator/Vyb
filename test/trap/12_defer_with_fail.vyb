# Test 12: Defer statements with fail - cleanup on error
# Tests that defer cleanup runs even when function fails

process_file(path<String>)<Int> -> {
    file<File> = File.open(path)
    defer file.close()  # Must run even if we fail

    buffer<my<Vec<Byte>>> = Vec.new()
    defer buffer.clear()  # Must run even if we fail

    # This might fail
    if (file.size() > 1000000) {
        fail FileTooLarge { path = path, size = file.size() }
    }

    content<String> = file.read_all()
    return content.length()
}

main()<Int> -> {
    result<Int> = {
        process_file("/tmp/huge_file.txt")
    } trap (e<FileTooLarge>) -> {
        println("File too large: " + e.path + " (" + e.size.to_string() + " bytes)")
        # Defer statements in process_file should have already run
        return -1
    }

    println("Result: " + result.to_string())
    return 0
}
