// @expect-return: 14
# Minimal reproduction of the bug
divide(a<Int>, b<Int>)<Int> -> {
    if (b == 0) { fail 42 }
    return a / b
}

compute(x<Int>, y<Int>)<Int> -> {
    result<Int> = divide(x, y)
    return result + 10
}

main()<Int> -> {
    # Call 1: No trap around this - should succeed and return 15
    val1<Int> = compute(10, 2)
    
    # Call 2: Trap around this - should catch error
    val2<Int> = {
        compute(10, 0)  # This will fail
    } trap (e<Int>) -> {
        -1
    }
    
    return val1 + val2  # Should return 15 + (-1) = 14
}
