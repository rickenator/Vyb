# Test 06: Multiple trap clauses - type-based dispatch
# Tests that the first matching trap catches the error

main()<Int> -> {
    # Test specific error type
    result1<Int> = {
        fail FileNotFound { path = "/tmp/missing.txt" }
        return 0
    } trap (e<FileNotFound>) -> {
        println("Caught FileNotFound: " + e.path)
        return 1
    } trap (e<IOError>) -> {
        println("Caught IOError (should not reach)")
        return 2
    } trap (e<Error>) -> {
        println("Caught generic Error (should not reach)")
        return 3
    }

    # Test middle trap
    result2<Int> = {
        fail IOError { message = "Disk full" }
        return 0
    } trap (e<FileNotFound>) -> {
        println("FileNotFound (should not reach)")
        return 1
    } trap (e<IOError>) -> {
        println("Caught IOError: " + e.message)
        return 2
    } trap (e<Error>) -> {
        println("Generic Error (should not reach)")
        return 3
    }

    println("Results: " + result1.to_string() + ", " + result2.to_string())
    return 0
}
