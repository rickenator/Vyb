# Test two calls - both success
divide(a<Int>, b<Int>)<Int> -> {
    if (b == 0) {
        fail 42
    }
    return a / b
}

compute(x<Int>, y<Int>)<Int> -> {
    result<Int> = divide(x, y)
    return result + 10
}

main()<Int> -> {
    val1<Int> = compute(10, 2)   # Should return 15
    val2<Int> = compute(6, 3)    # Should return 12 (6/3=2, +10=12)
    return val1 + val2           # 15 + 12 = 27
}
