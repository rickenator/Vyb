// Test Vec iteration with break
main()<Int> -> {
    v<Vec<Int>> = Vec::new();
    v.push(1);
    v.push(2);
    v.push(3);
    v.push(4);
    v.push(5);
    
    var<Int> sum = 0;
    for (x in v) {
        if (sum >= 6) {
            break;
        }
        sum = sum + x;
    }
    return sum;  // Should return 6 (1+2+3, then breaks before adding 4)
}
