// Comprehensive range-based for loop tests

main()<Int> -> {
    // Test 1: Simple inclusive range
    var<Int> sum1 = 0;
    for (i in 0..4) {
        sum1 = sum1 + i;
    }
    if (sum1 != 10) {  // 0+1+2+3+4
        return 1;
    }

    // Test 2: Range with step
    var<Int> sum2 = 0;
    for (i in 0..10, 2) {
        sum2 = sum2 + i;
    }
    if (sum2 != 30) {  // 0+2+4+6+8+10
        return 2;
    }

    // Test 3: Break in range loop
    var<Int> sum3 = 0;
    for (i in 0..10) {
        if (i > 3) {
            break;
        }
        sum3 = sum3 + i;
    }
    if (sum3 != 6) {  // 0+1+2+3
        return 3;
    }

    // Test 4: Continue in range loop
    var<Int> sum4 = 0;
    for (i in 0..10) {
        if (i == 5) {
            continue;
        }
        sum4 = sum4 + i;
    }
    if (sum4 != 50) {  // 0+1+2+3+4+6+7+8+9+10 = 50
        return 4;
    }

    // Test 5: Negative range
    var<Int> sum5 = 0;
    for (i in -2..2) {
        sum5 = sum5 + i;
    }
    if (sum5 != 0) {  // -2+-1+0+1+2 = 0
        return 5;
    }

    return 0;  // All tests passed!
}
