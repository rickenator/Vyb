// Test Vec with chained push operations
// @expect-return: 150

main()<Int> -> {
    // Test chained push - more concise syntax
    numbers<Vec<Int>> = Vec::new();
    numbers.push(10).push(20).push(30).push(40).push(50);
    
    sum<Int> = 0;
    for (num in numbers) {
        sum = sum + num;
    }
    
    return sum;  // Should return 150 (10+20+30+40+50)
}
