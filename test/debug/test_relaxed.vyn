// Main test file for relaxed syntax features

// Import helper functions from other test files
import test_relaxed_basic
import test_relaxed_syntax
import test_relaxed_local

// Main test runner
fn<Int> main() -> {
    println("Running relaxed syntax tests...")
    
    // Run all test suites
    test_relaxed_basic::run_basic_tests()
    test_relaxed_syntax::run_syntax_tests() 
