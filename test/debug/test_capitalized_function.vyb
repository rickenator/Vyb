// @test: Capitalized function test
// @description: Test that capitalized type constructors still work as regular functions
// @category: debug
// @expect: pass
// @expect-return: 30
// Test that capitalized type constructors still work

Point(x<Int>, y<Int>)<Int> -> {
    return x + y;
}

main()<Int> -> {
    // This should still be parsed as a CallExpression since Point starts with capital
    // but is actually a function, not a type constructor
    return Point(10, 20);
}
