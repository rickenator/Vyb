// Comprehensive test for semantic-codegen type alias integration
type<Int> UserId;
type<String> UserName;
type<Int8> Score;

getUserId()<UserId> -> {
    return 42;
}

getUserName()<UserName> -> {
    return "Alice";
}

getScore()<Score> -> {
    return 100;
}

main()<Int> -> {
    id<UserId> = getUserId();
    name<UserName> = getUserName();
    score<Score> = getScore();

    return 0;
}
