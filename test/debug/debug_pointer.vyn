// @test: Debug: Pointer Return
// @description: Debug: Pointer Return
// @category: debug
// @expect: pass
// @expect-return: 42
// Debug pointer assignment step by step
main()<Int> -> {
    x<Int> = 42;
    print("Initial x:", x);
    
    freedom {
        p<loc<Int>> = loc(x);
        print("Before at(p) assignment, x:", x);
        at(p) = 100;
        print("After at(p) assignment, x:", x);
    }
    
    return x;
}