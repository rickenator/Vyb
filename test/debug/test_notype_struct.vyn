// @test: notype() Intrinsic with Structs
// @description: Tests the notype() intrinsic for suppressing type metadata in struct field names
// @category: intrinsic, json, serialization, struct
// @expect: pass
// @expect-output: [{"Person":{"id":123,"name":"Alice","salary":88000.0}},{"Company":{"name<String>":"Acme","employeeCount<Int>":150}}]

// Test notype() intrinsic with actual structs (proper usage)

struct Person {
    Int id,
    String name, 
    Float salary
}

struct Company {
    String name,
    Int employeeCount
}

main()<Person, Company> -> {
    person<Person> = Person(id=123, name="Alice", salary=88000.0);
    company<Company> = Company(name="Acme", employeeCount=150);
    return notype(person), company;
}
