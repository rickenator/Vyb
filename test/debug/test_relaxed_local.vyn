// @expect: fail
// Tests for relaxed syntax with local variables

// Test local variable declarations with relaxed syntax
@test
fn test_local_vars() -> {
    // Relaxed syntax for local variables
    Int count = 5                  // Equivalent to count<Int> = 5
    String message = "Hello"       // Equivalent to message<String> = "Hello"
    
    // Variable assignment
    count = 10
    message = message + " World"
    
    assert(count == 10)
    assert(message == "Hello World")
    
    // Immutable with relaxed syntax
    const Bool flag = true         // Equivalent to const<Bool> flag = true
    assert(flag)
    
    // Type inference with 'auto'
    auto sum = count + 5           // Inferred as Int
    auto greeting = message + "!"  // Inferred as String
    
    assert(sum == 15)
    assert(greeting == "Hello World!")
}

// Test relaxed syntax in complex scenarios
@test
fn test_complex_scenarios() -> {
    // Nested blocks with local variables
    {
        Int x = 1
        {
            Int y = 2
            assert(x + y == 3)
        }
    }
    
    // Multiple declarations
    Int a = 1, b = 2, c = 3
    assert(a + b + c == 6)
    
    // Initialization from function calls
    Int result = get_number()
    assert(result == 42)
}

// Helper function
get_number()<Int> -> {
    return 42
}

// Public function to run all tests in this file
fn run_local_tests() -> {
    println("Running local variable tests...")
    test_local_vars()
    test_complex_scenarios()
    println("Local variable tests passed!")
}