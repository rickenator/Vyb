// @test: Phase2 propagation reaches top-level untrapped handler
// @description: A failing callee propagates through one failable caller and reaches untrapped runtime handling at top level.
// @category: trap,error
// @expect: fail
// @expect-error: UNTRAPPED FAILURE

always_fail()<Int> -> {
    fail<Int>(77)
    return 0
}

middle_layer()<Int> -> {
    x<Int> = always_fail()
    return x + 1
}

main()<Int> -> {
    y<Int> = middle_layer()
    return y
}
