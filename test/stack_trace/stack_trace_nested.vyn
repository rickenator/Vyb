// Test: Nested function calls with stack trace
// This demonstrates a 3-level call stack when an error occurs

level3()<Int> -> {
    println("At level 3 - about to fail")
    fail "Error occurred at deepest level"
    return 0
}

level2()<Int> -> {
    println("At level 2 - calling level 3")
    return level3()
}

level1()<Int> -> {
    println("At level 1 - calling level 2")
    return level2()
}

main()<Int> -> {
    println("=== Stack Trace Test: Nested Calls ===")
    return level1()
}
