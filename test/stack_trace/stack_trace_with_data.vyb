// Test: Stack trace with function parameters
// Shows stack trace with context about what was being processed

processValue(value<Int>)<Int> -> {
    println("Processing value")
    if (value < 0) {
        fail "Negative values not allowed"
    }
    if (value > 100) {
        fail "Value exceeds maximum (100)"
    }
    return value * 2
}

validateAndProcess(input<Int>)<Int> -> {
    println("Validating input")
    return processValue(input)
}

handleRequest(requestId<Int>)<Int> -> {
    println("Handling request")
    return validateAndProcess(requestId)
}

main()<Int> -> {
    println("=== Stack Trace Test: Error With Context ===")
    println("Processing valid value (50):")
    var<Int> valid = handleRequest(50)

    println("Processing invalid value (150):")
    var<Int> invalid = handleRequest(150)

    return 0
}
