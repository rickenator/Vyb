# Test mild<T> ownership type (weak references)
# mild<T> provides non-owning references to our<T> objects
# Key methods: grab() -> our<T>?, released() -> Bool

struct TreeNode {
    value<Int>
}

create_tree()<our<TreeNode>> -> {
    return our(TreeNode { value: 1 })
}

# Example 1: Using soft() to create a mild reference
capture_parent(node<our<TreeNode>>)<Int> -> {
    weak<mild<TreeNode>> = soft(node)
    parent_strong<our<TreeNode>> = weak.grab()
    return parent_strong.value
}

# Example 2: Using released() to check status
check_parent_alive(node<our<TreeNode>>)<Bool> -> {
    weak<mild<TreeNode>> = soft(node)
    return !weak.released()
}

main()<Int> -> {
    tree<our<TreeNode>> = create_tree()
    parent_value<Int> = capture_parent(tree)
    alive<Bool> = check_parent_alive(tree)
    
    if (parent_value == 1 && alive) {
        println("Successfully used mild<T> grab() and released()")
        return 0
    }
    
    return 1
}
