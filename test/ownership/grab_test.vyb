// Test grab() method: upgrading mild<T> to our<T>

struct Data {
    value<Int>
}

main()<Int> -> {
    println("=== Testing mild<T>.grab() ===")
    println("")

    // Test 1: grab() while object is alive
    println("Test 1: grab() while object is alive")
    shared<our<Data>> = our(Data { value: 100 })
    weak<mild<Data>> = soft(shared)

    // Try to grab a strong reference
    grabbed<our<Data>> = weak.grab()

    // grabbed should be non-nil (object still alive)
    // TODO: Once we have nil comparison, test this properly
    println("  grab() called successfully")

    println("")

    // Test 2: Demonstrate grab() increments strong_count
    println("Test 2: grab() increments reference count")
    data1<our<Data>> = our(Data { value: 200 })
    shadow<mild<Data>> = soft(data1)

    // Create another strong reference via grab
    data2<our<Data>> = shadow.grab()

    println("  Both strong references active")
    println("  (data1 and data2 both point to same object)")

    println("")
    println("=== All grab() tests completed ===")
    return 0
}
