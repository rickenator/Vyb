// Test that our<T> control blocks properly clean up objects
// when strong_count reaches zero

struct Node {
    value<Int>
}

main()<Int> -> {
    println("=== our<T> Control Block Cleanup Test ===")
    println("")
    
    println("1. Creating our<Node> in inner scope...")
    {
        inner<our<Node>> = our(Node { value: 42 })
        println("   our<Node> created with value=42")
        println("   (Control block should be freed when scope exits)")
    }
    println("   Scope exited - object should be freed")
    println("")
    
    println("2. Creating multiple our<T> references (future test)...")
    println("   (Requires assignment/copy which isn't implemented yet)")
    println("")
    
    println("✓ Test complete - if no segfault, cleanup worked!")
    return 0
}
