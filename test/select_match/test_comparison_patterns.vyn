// Test comparison patterns in match and select statements

test_match_integer_comparisons()<Int> -> {
    score<Int const> = 85
    
    match (score) {
        >= 90 -> { return 1 },  // A grade
        >= 80 -> { return 2 },  // B grade
        >= 70 -> { return 3 },  // C grade
        >= 60 -> { return 4 },  // D grade
        ? -> { return 5 }       // F grade
    }
}

test_match_less_than()<Int> -> {
    age<Int const> = 16
    
    match (age) {
        < 13 -> { return 1 },   // child
        < 18 -> { return 2 },   // teen
        < 65 -> { return 3 },   // adult
        ? -> { return 4 }       // senior
    }
}

test_match_equality()<Int> -> {
    value<Int const> = 42
    
    match (value) {
        == 42 -> { return 100 },
        == 0 -> { return 0 },
        ? -> { return -1 }
    }
}

test_match_inequality()<Int> -> {
    value<Int const> = 5
    
    match (value) {
        != 0 -> { return 1 },  // non-zero
        ? -> { return 0 }      // zero
    }
}

test_select_integer_comparisons()<Int> -> {
    score<Int const> = 75
    
    grade<Int const> = select(score) -> {
        >= 90 -> 1,   // A
        >= 80 -> 2,   // B
        >= 70 -> 3,   // C
        >= 60 -> 4,   // D
        ? -> 5        // F
    }
    
    return grade
}

test_select_less_than()<Int> -> {
    age<Int const> = 25
    
    category<Int const> = select(age) -> {
        < 13 -> 1,   // child
        < 18 -> 2,   // teen
        < 65 -> 3,   // adult
        ? -> 4       // senior
    }
    
    return category
}

test_select_equality()<Int> -> {
    value<Int const> = 42
    
    result<Int const> = select(value) -> {
        == 42 -> 100,
        == 0 -> 0,
        ? -> -1
    }
    
    return result
}

test_select_inequality()<Int> -> {
    value<Int const> = 5
    
    result<Int const> = select(value) -> {
        != 0 -> 1,  // non-zero
        ? -> 0      // zero
    }
    
    return result
}

test_float_comparisons()<Int> -> {
    temperature<Float const> = 72.5
    
    comfort<Int const> = select(temperature) -> {
        >= 80.0 -> 1,   // hot
        >= 70.0 -> 2,   // warm
        >= 60.0 -> 3,   // cool
        ? -> 4          // cold
    }
    
    return comfort
}

main()<Int> -> {
    // Test match with integer comparisons
    result1<Int const> = test_match_integer_comparisons()
    if (result1 != 2) {  // 85 should be B grade (2)
        return 1
    }
    
    result2<Int const> = test_match_less_than()
    if (result2 != 2) {  // 16 should be teen (2)
        return 2
    }
    
    result3<Int const> = test_match_equality()
    if (result3 != 100) {  // 42 == 42 should return 100
        return 3
    }
    
    result4<Int const> = test_match_inequality()
    if (result4 != 1) {  // 5 != 0 should return 1
        return 4
    }
    
    // Test select with integer comparisons
    result5<Int const> = test_select_integer_comparisons()
    if (result5 != 3) {  // 75 should be C grade (3)
        return 5
    }
    
    result6<Int const> = test_select_less_than()
    if (result6 != 3) {  // 25 should be adult (3)
        return 6
    }
    
    result7<Int const> = test_select_equality()
    if (result7 != 100) {  // 42 == 42 should return 100
        return 7
    }
    
    result8<Int const> = test_select_inequality()
    if (result8 != 1) {  // 5 != 0 should return 1
        return 8
    }
    
    // Test float comparisons
    result9<Int const> = test_float_comparisons()
    if (result9 != 2) {  // 72.5 should be warm (2)
        return 9
    }
    
    return 0  // All tests passed!
}
