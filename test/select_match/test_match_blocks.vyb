// Test match with multi-line block expressions
// Blocks can now be used in match arms with { statement; statement; ... }

test_match_with_blocks(x<Int const>)<Int> -> {
    match (x) {
        0 -> {
            println("Found zero")
            println("Returning 100")
            return 100
        },
        1 -> {
            y<Int const> = x * 10
            println("One times 10 is:")
            println(y)
            return y
        },
        2 -> {
            a<Int const> = x + 5
            b<Int const> = a * 2
            println("Computed value:")
            println(b)
            return b
        },
        ? -> {
            println("Default case")
            println("Input was:")
            println(x)
            result<Int const> = x * x
            return result
        }
    }
}

test_match_simple(x<Int const>)<Void> -> {
    println("Testing value:")
    println(x)

    match (x) {
        0 -> println("zero"),
        1 -> println("one"),
        42 -> println("forty-two"),
        ? -> println("other")
    }
}

test_match_mixed(x<Int const>)<Void> -> {
    match (x) {
        0 -> println("zero"),
        1 -> {
            println("Found one!")
            println("Extra line for one")
        },
        2 -> println("two"),
        ? -> {
            println("Other number:")
            println(x)
        }
    }
}

main()<Int> -> {
    println("Testing match with block expressions:")

    r1<Int const> = test_match_with_blocks(0)
    println("Result for 0:")
    println(r1)

    r2<Int const> = test_match_with_blocks(1)
    println("Result for 1:")
    println(r2)

    r3<Int const> = test_match_with_blocks(2)
    println("Result for 2:")
    println(r3)

    r4<Int const> = test_match_with_blocks(42)
    println("Result for 42:")
    println(r4)

    println("\nTesting simple match:")
    test_match_simple(42)

    println("\nTesting mixed styles:")
    test_match_mixed(1)
    test_match_mixed(99)

    return 0
}
