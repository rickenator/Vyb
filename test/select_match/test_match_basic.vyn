// Test basic match statement functionality

test_int_match()<Void> -> {
    x<Int const> = 42
    
    match (x) {
        0 -> println("zero"),
        1 -> println("one"),
        42 -> println("forty-two"),
        ? -> println("other")
    }
}

test_enum_like()<Void> -> {
    status<Int const> = 1
    
    match (status) {
        0 -> println("init"),
        1 -> println("running"),
        2 -> println("done"),
        ? -> println("unknown status")
    }
}

main()<Void> -> {
    println("Testing match statement:")
    test_int_match()
    test_enum_like()
}
