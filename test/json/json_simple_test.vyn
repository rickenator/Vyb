// Simpler JSON test to debug field access

struct Person {
    name<String>,
    age<Int>
}

main()<Int> -> {
    // Create original
    p1<Person> = Person { name: "Alice", age: 30 }
    println(p1.name)
    println(p1.age.to_string())
    
    // Serialize
    json<String> = p1.to_string()
    println(json)
    
    // Deserialize
    p2<Person> = Person::from_string(json)
    println("P2 loaded")
    
    // Try to access fields
    name2<String> = p2.name
    println("Got name2")
    println(name2)
    
    return 0
}
