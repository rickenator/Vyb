main()<Int> -> {
    i<Int> = 42
    f<Float> = 3.14
    b<Bool> = true

    // to_string() converts any primitive to a String
    println(i.to_string())
    println(f.to_string())
    println(b.to_string())

    // String concatenation with + auto-converts via to_string()
    println("Value: " + i.to_string())
    println("Float: " + f.to_string())
    println("Bool: " + b.to_string())

    return 0
}
