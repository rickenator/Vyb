// @expect-return: 80
# Test optimization passes
# This program has opportunities for optimization:
# - Dead code elimination
# - Constant folding
# - Common subexpression elimination

compute(x<Int>)<Int> -> {
    # Constant folding opportunity
    a<Int> = 10 + 20 + 30

    # Common subexpression
    b<Int> = x * 2
    c<Int> = x * 2

    # Dead code (never used)
    unused<Int> = 100 * 200

    # Return using CSE result
    return a + b + c
}

main()<Int> -> {
    result<Int> = compute(5)
    return result
}
