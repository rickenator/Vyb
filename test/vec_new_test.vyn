// Test Vec::new() and basic operations

struct TreeNode {
    key<Int>,
    value<String>
}

main()<Int> -> {
    nodes<Vec<TreeNode>> = Vec::new()
    println("Created empty Vec")
    
    node1<TreeNode> = TreeNode { key = 10, value = "ten" }
    nodes.push(node1)
    println("Pushed first node")
    
    size<Int> = nodes.len()
    println("Size after push")
    
    return size
}
