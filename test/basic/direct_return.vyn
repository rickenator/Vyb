// @test: Direct Multi-value Return
// @description: Tests directly returning the result of a function with multiple return values
// @category: syntax, function, json
// @expect: pass
// @expect-output: {"Int":42,"String":"Hello, World!"}

// Function that returns multiple values (Int and String)
get_values()<Int, String> -> {
    return 42, "Hello, World!";
}

// Main function directly returns the get_values() call
main()<Int, String> -> {
    return get_values();
}
