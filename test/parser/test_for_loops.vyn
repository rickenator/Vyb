# Test for loops with different patterns

## Simple counting loop (sum 0..4)
test_simple_for()<Int> -> {
    sum<Int> = 0
    for (i<Int> = 0; i < 5; i = i + 1) {
        sum = sum + i
    }
    return sum  # Expected: 10
}

## Different increment
test_step_for()<Int> -> {
    sum<Int> = 0
    for (i<Int> = 0; i < 10; i = i + 2) {
        sum = sum + i
    }
    return sum  # Expected: 0 + 2 + 4 + 6 + 8 = 20
}

## Countdown
test_countdown_for()<Int> -> {
    sum<Int> = 0
    for (i<Int> = 5; i > 0; i = i - 1) {
        sum = sum + i
    }
    return sum  # Expected: 5 + 4 + 3 + 2 + 1 = 15
}