fn test_arithmetic() -> i32 {
    let a: i32 = 10;
    let b: i32 = 20;
    
    // Test basic arithmetic
    let sum = a + b;      // 30
    let diff = b - a;     // 10
    let product = a * b;  // 200
    let quotient = b / a; // 2
    let remainder = b % a; // 0
    
    return sum + diff;  // Should return 40
}

fn test_comparisons() -> bool {
    let x: i32 = 15;
    let y: i32 = 25;
    
    // Test comparison operators
    let eq = x == x;     // true
    let neq = x != y;    // true
    let lt = x < y;      // true
    let lte = x <= y;    // true
    let gt = y > x;      // true
    let gte = y >= x;    // true
    
    return eq && neq && lt && lte && gt && gte;
}

fn test_float_ops() -> f64 {
    let a: f64 = 3.14;
    let b: f64 = 2.0;
    
    let sum = a + b;
    let product = a * b;
    
    return sum + product; // 3.14 + 2.0 + 3.14 * 2.0 = 5.14 + 6.28 = 11.42
}

fn main() -> i32 {
    let arith_result = test_arithmetic();
    let comp_result = test_comparisons();
    let float_result = test_float_ops();
    
    return arith_result; // Should return 40
}