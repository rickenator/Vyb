// @test: Employee Struct Example
// @description: Simple example showing Employee struct initialization and return from main
// @category: struct, basic, json
// @expect: pass

struct Employee {
    String name,
    Int id,
    Float salary,
    Bool isActive
}

createEmployee()<Employee> -> {
    emp<Employee> = Employee {
        name = "John Doe",
        id = 1001,
        salary = 75000.0,
        isActive = true
    };
    return emp;
}

main()<Employee> -> {
    employee<Employee> = createEmployee();
    return employee;
}
