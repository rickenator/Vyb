struct Person {
    string name,
    i64 age,
    f64 height
}

fn<Person> create_person() -> {
    var<Person> person = {
        name = "Alice Smith",
        age = 30,
        height = 1.75
    };
    return person;
}

fn main() -> i32 {
    let person = create_person();
    __vyn_serialize_to_json(person);
    return 0;
}
