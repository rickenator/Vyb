// Test case for parser error handling on incorrect function syntax
// This test verifies that the parser correctly detects the common mistake
// of using C-style function syntax instead of VyB syntax

// Correct VyB syntax (this should work):
correct_syntax()<String> -> {
    return "works";
}

main()<String> -> {
    return correct_syntax();
}

// Note: The following would cause a helpful error message:
// fn incorrect_syntax() -> String {
//     return "error";
// }
// Error: "Invalid function syntax. VyB uses 'fn<ReturnType> name()' syntax, not 'fn name() -> ReturnType'"
