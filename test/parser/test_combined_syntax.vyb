// Test file using both angle bracket and colon syntax together

// Struct with both syntaxes
struct MixedPoint {
    x<Int>,   // Angle bracket syntax
    y: Int    // Colon syntax
}

// Simple test to create and return a point
main()<MixedPoint> -> {
    p<MixedPoint> = MixedPoint { x=10, y=20 };
    return p;
}
