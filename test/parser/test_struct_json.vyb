struct Person {
    string name,
    i64 age,
    f64 height
}

create_person()<Person> -> {
    person<Person> = {
        name = "Alice Smith",
        age = 30,
        height = 1.75
    };
    return person;
}

fn main() -> i32 {
    let person = create_person();
    __vyb_serialize_to_json(person);
    return 0;
}
