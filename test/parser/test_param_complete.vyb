// Test all supported parameter syntax variations
test_standard(a<Int>, const<Int> b)<Int> -> {
    return a + b;
}

test_shorthand(Int a, const Int b)<Int> -> {
    return a * b;
}

test_mixed(x<Int>, Int y, const<Int> z)<Int> -> {
    return x + y + z;
}

main()<Int> -> {
    r1<Int> = test_standard(10, 5);    // 15
    r2<Int> = test_shorthand(4, 3);    // 12
    r3<Int> = test_mixed(1, 2, 3);     // 6
    return r1 + r2 + r3;                   // 33
}