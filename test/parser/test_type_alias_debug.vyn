// Test file to verify the new type alias syntax works with actual output
type<Int> UserId;
type<String> UserName;
type<Int8> Score;

getUserId()<UserId> -> {
    return 42;
}

getUserName()<UserName> -> {
    return "Alice";
}

getScore()<Score> -> {
    return 100;
}

main()<UserId, UserName, Score> -> {
    id<UserId> = getUserId();
    name<UserName> = getUserName();  
    score<Score> = getScore();
    
    println("User ID: " + id);
    println("User Name: " + name);
    println("Score: " + score);
    
    return id,name,score;
}
