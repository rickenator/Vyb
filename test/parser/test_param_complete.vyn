// Test all supported parameter syntax variations
fn<Int> test_standard(var<Int> a, const<Int> b) -> {
    return a + b;
}

fn<Int> test_shorthand(Int a, const Int b) -> {
    return a * b;
}

fn<Int> test_mixed(var<Int> x, Int y, const<Int> z) -> {
    return x + y + z;
}

fn<Int> main() -> {
    var<Int> r1 = test_standard(10, 5);    // 15
    var<Int> r2 = test_shorthand(4, 3);    // 12  
    var<Int> r3 = test_mixed(1, 2, 3);     // 6
    return r1 + r2 + r3;                   // 33
}