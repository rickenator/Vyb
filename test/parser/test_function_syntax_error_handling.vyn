// Test case for parser error handling on incorrect function syntax
// This test verifies that the parser correctly detects the common mistake 
// of using C-style function syntax instead of Vyn syntax

// Correct Vyn syntax (this should work):
fn<String> correct_syntax() -> {
    return "works";
}

fn<String> main() -> {
    return correct_syntax();
}

// Note: The following would cause a helpful error message:
// fn incorrect_syntax() -> String {
//     return "error";
// }
// Error: "Invalid function syntax. Vyn uses 'fn<ReturnType> name()' syntax, not 'fn name() -> ReturnType'"
