// @test: Multi-value Return Parser Test
// @description: Tests that multi-value return statements parse correctly
// @category: parser, syntax, function
// @expect: pass
// @expect-output: {"String":"hello","Int":42,"Bool":true}

// Function that returns multiple values to test parsing
test_function()<String, Int, Bool> -> {
    return "hello", 42, true;
}

// Main function that calls test_function and returns the multi-value result
main()<String, Int, Bool> -> {
    return test_function();
}
