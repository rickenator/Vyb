// @test: Quicksort
// @description: Recursive quicksort on Vec<Int>; verifies output is sorted by checking pairwise order
// @category: algorithms, vec
// @expect: pass
// @expect-output: 1

quicksort(nums<Vec<Int>>)<Vec<Int>> -> {
    if (nums.len() <= 1) {
        return nums
    }
    pivot<Int> = nums.get(nums.len() / 2)
    left<Vec<Int>>  = Vec::new()
    equal<Vec<Int>> = Vec::new()
    right<Vec<Int>> = Vec::new()
    i<Int> = 0
    while (i < nums.len()) {
        elem<Int> = nums.get(i)
        if (elem < pivot) {
            left.push(elem)
        } else if (elem > pivot) {
            right.push(elem)
        } else {
            equal.push(elem)
        }
        i = i + 1
    }
    left_sorted<Vec<Int>>  = quicksort(left)
    right_sorted<Vec<Int>> = quicksort(right)
    result<Vec<Int>> = Vec::new()
    i = 0
    while (i < left_sorted.len()) {
        result.push(left_sorted.get(i))
        i = i + 1
    }
    i = 0
    while (i < equal.len()) {
        result.push(equal.get(i))
        i = i + 1
    }
    i = 0
    while (i < right_sorted.len()) {
        result.push(right_sorted.get(i))
        i = i + 1
    }
    return result
}

is_sorted(nums<Vec<Int>>)<Bool> -> {
    i<Int> = 1
    while (i < nums.len()) {
        if (nums.get(i) < nums.get(i - 1)) {
            return false
        }
        i = i + 1
    }
    return true
}

main()<Int> -> {
    nums<Vec<Int>> = Vec::new()
    nums.push(9)
    nums.push(3)
    nums.push(7)
    nums.push(1)
    nums.push(5)
    nums.push(8)
    nums.push(2)
    nums.push(6)
    nums.push(4)
    sorted<Vec<Int>> = quicksort(nums)
    if (is_sorted(sorted)) {
        println_int(1)
    } else {
        println_int(0)
    }
    return 0
}
