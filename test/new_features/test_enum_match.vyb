// @test: Enum with match statement
// @description: Enum variants can be used with match for dispatch
// @category: types, enum, match
// @expect: pass
// @expect-output: East
// @expect-output: 0

enum Direction { North, South, East, West }

main()<Int> -> {
    d<Int> = Direction::East
    match (d) {
        0 -> println("North"),
        2 -> println("East"),
        ? -> println("Other")
    }
    return 0
}
