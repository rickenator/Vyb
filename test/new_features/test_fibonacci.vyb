// @test: Fibonacci function
// @description: Test recursive Fibonacci function
// @category: functions
// @expect: pass
// @expect-output: 55

fib(n<Int>)<Int> -> {
    if (n <= 1) {
        return n
    }
    return fib(n - 1) + fib(n - 2)
}

main()<Int> -> {
    result<Int> = fib(10)
    println_int(result)
    return 0
}
