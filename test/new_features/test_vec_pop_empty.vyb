// @test: Vec pop empty returns default value
// @description: Vec.pop() on an empty Vec<Int> does not dereference null storage
// @category: vec, data_structures
// @expect: pass
// @expect-output: 0

main()<Int> -> {
    v<Vec<Int>> = Vec::new()
    removed<Int> = v.pop()
    println_int(removed)
    return 0
}
