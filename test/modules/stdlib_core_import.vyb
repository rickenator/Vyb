// @test: Stdlib core option import via VYB_STDLIB
// @description: import core::option resolves from VYB_STDLIB without --module-path
// @category: modules
// @expect: pass
// @expect-output: 7
// @env: VYB_STDLIB=stdlib

import core::option::{OptionInt, option_int_some, option_int_unwrap_or}

main()<Int> -> {
    value<OptionInt> = option_int_some(7)
    println_int(option_int_unwrap_or(value, 0))
    return 0
}
