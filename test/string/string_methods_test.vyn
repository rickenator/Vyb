// Test all String method functionality

test_substring() <Void> -> {
    msg<String> = String::from_bytes("Hello World", 11)
    
    // Test basic substring
    sub1<String> = msg.substring(0, 5)
    print("substring(0, 5) length: ")
    println_int(sub1.len())
    
    // Test substring with end
    sub2<String> = msg.substring(6, 11)
    print("substring(6, 11) length: ")
    println_int(sub2.len())
    
    // Test substring to end
    sub3<String> = msg.substring(6)
    print("substring(6) length: ")
    println_int(sub3.len())
}

test_char_at() <Void> -> {
    msg<String> = String::from_bytes("Hello", 5)
    
    // Test first character (should be 'H' = 72)
    ch1<Int> = msg.char_at(0)
    print("char_at(0) = ")
    println_int(ch1)
    
    // Test last character (should be 'o' = 111)
    ch2<Int> = msg.char_at(4)
    print("char_at(4) = ")
    println_int(ch2)
    
    // Test out of bounds (should be 0)
    ch3<Int> = msg.char_at(10)
    print("char_at(10) out of bounds = ")
    println_int(ch3)
}

test_starts_with() <Void> -> {
    msg<String> = String::from_bytes("Hello World", 11)
    prefix1<String> = String::from_bytes("Hello", 5)
    prefix2<String> = String::from_bytes("World", 5)
    
    // Should be true
    result1<Bool> = msg.starts_with(prefix1)
    print("starts_with('Hello'): ")
    println_int(result1)
    
    // Should be false
    result2<Bool> = msg.starts_with(prefix2)
    print("starts_with('World'): ")
    println_int(result2)
}

test_ends_with() <Void> -> {
    msg<String> = String::from_bytes("Hello World", 11)
    suffix1<String> = String::from_bytes("World", 5)
    suffix2<String> = String::from_bytes("Hello", 5)
    
    // Should be true
    result1<Bool> = msg.ends_with(suffix1)
    print("ends_with('World'): ")
    println_int(result1)
    
    // Should be false
    result2<Bool> = msg.ends_with(suffix2)
    print("ends_with('Hello'): ")
    println_int(result2)
}

test_contains() <Void> -> {
    msg<String> = String::from_bytes("Hello World", 11)
    sub1<String> = String::from_bytes("lo Wo", 5)
    sub2<String> = String::from_bytes("xyz", 3)
    
    // Should be true
    result1<Bool> = msg.contains(sub1)
    print("contains('lo Wo'): ")
    println_int(result1)
    
    // Should be false
    result2<Bool> = msg.contains(sub2)
    print("contains('xyz'): ")
    println_int(result2)
}

test_to_upper() <Void> -> {
    msg<String> = String::from_bytes("Hello World", 11)
    
    upper<String> = msg.to_upper()
    print("to_upper length: ")
    println_int(upper.len())
    
    // Check first character is 'H' = 72 (already uppercase)
    ch<Int> = upper.char_at(0)
    print("First char after to_upper: ")
    println_int(ch)
}

test_to_lower() <Void> -> {
    msg<String> = String::from_bytes("Hello World", 11)
    
    lower<String> = msg.to_lower()
    print("to_lower length: ")
    println_int(lower.len())
    
    // Check first character is 'h' = 104 (lowercase)
    ch<Int> = lower.char_at(0)
    print("First char after to_lower: ")
    println_int(ch)
}

main() <Int> -> {
    println("=== String::substring() ===")
    test_substring()
    
    println("=== String::char_at() ===")
    test_char_at()
    
    println("=== String::starts_with() ===")
    test_starts_with()
    
    println("=== String::ends_with() ===")
    test_ends_with()
    
    println("=== String::contains() ===")
    test_contains()
    
    println("=== String::to_upper() ===")
    test_to_upper()
    
    println("=== String::to_lower() ===")
    test_to_lower()
    
    return 0
}

