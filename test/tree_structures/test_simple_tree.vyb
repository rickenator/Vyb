// Simplified tree test to isolate the issue
struct SimpleNode {
    value<Int>
}

struct SimpleTree {
    node<my<SimpleNode>>,
    has_node<Bool>
}

add_node(tree<their<SimpleTree>>, val<Int>)<Void> -> {
    if (!tree.has_node) {
        tree.node = my(SimpleNode { value = val })
        tree.has_node = true
    }
}

main()<Int> -> {
    my_tree<SimpleTree> = SimpleTree {
        node = my(SimpleNode { value = 0 }),
        has_node = false
    }

    println("Before:")
    println("Has node: " + my_tree.has_node.to_string())

    add_node(borrow(my_tree), 42)

    println("After:")
    println("Has node: " + my_tree.has_node.to_string())

    return 0
}