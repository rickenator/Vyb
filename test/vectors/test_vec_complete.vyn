main()<Int> -> {
    // Test Vec::new() constructor
    numbers<Vec<Int>> = Vec::new();
    
    // Test Vec::push() method
    numbers.push(10);
    numbers.push(20);
    numbers.push(30);
    
    // Test Vec::len() method
    length<Int> = numbers.len();
    println(length);
    
    // Test Vec::get() method
    first<Int> = numbers.get(0);
    println(first);
    
    // Test Vec::pop() method  
    popped<Int> = numbers.pop();
    println(popped);
    
    return 0;
}