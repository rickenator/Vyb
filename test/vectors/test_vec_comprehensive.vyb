// Test all new Vec methods comprehensively
main()<Int> -> {
    // Test basic Vec creation and manipulation
    vec<Vec<Int>> = Vec::new();
    println("New vec is_empty:", vec.is_empty());
    println("New vec capacity:", vec.capacity());
    println("New vec length:", vec.len());

    // Test push and chaining
    vec.push(1).push(2).push(3);
    println("After pushing 1,2,3:");
    println("Length:", vec.len());
    println("Empty?", vec.is_empty());
    println("Contents:", vec);

    // Test get method
    first<Int> = vec.get(0);
    second<Int> = vec.get(1);
    third<Int> = vec.get(2);
    println("Elements: ", first, second, third);

    // Test contains method
    has_two<Bool> = vec.contains(2);
    has_five<Bool> = vec.contains(5);
    println("Contains 2:", has_two);
    println("Contains 5:", has_five);

    // Test concat method
    vec2<Vec<Int>> = Vec::new();
    vec2.push(10).push(20);

    result<Vec<Int>> = vec.concat(vec2);
    println("After concat:");
    println("Result length:", result.len());
    println("Result contents:", result);

    // Test remove_at method
    removed<Int> = result.remove_at(1);  // Remove element at index 1
    println("Removed element:", removed);
    println("After removal length:", result.len());
    println("After removal contents:", result);

    // Test clear method
    result.clear();
    println("After clear:");
    println("Length:", result.len());
    println("Empty?", result.is_empty());

    // Test capacity management
    big_vec<Vec<Int>> = Vec::new();
    i<Int> = 0;
    while (i < 10) {
        big_vec.push(i * i);  // Push squares
        println("Length:", big_vec.len(), "Capacity:", big_vec.capacity());
        i = i + 1;
    }

    return 0;
}