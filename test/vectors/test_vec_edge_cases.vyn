// Test Vec edge cases and error conditions
main()<Int> -> {
    // Test empty Vec operations
    empty<Vec<Int>> = Vec::new()
    
    println("Testing empty Vec:")
    println("Empty length:", empty.len())
    println("Empty is_empty:", empty.is_empty())
    println("Empty capacity:", empty.capacity())
    
    // Test pop on empty Vec (should handle gracefully)
    popped<Int> = empty.pop()
    println("Popped from empty (should be safe):", popped)
    
    // Test get with invalid indices
    // These might cause runtime errors, but should be handled:
    // first = empty.get(0)       // Index out of bounds
    // negative = empty.get(-1)   // Negative index
    
    // Test large Vec operations
    large<Vec<Int>> = Vec::new()
    
    // Fill with many elements
    i<Int> = 0
    while (i < 100) {
        large.push(i)
        i = i + 1
    }
    
    println("Large Vec length:", large.len())
    println("Large Vec capacity:", large.capacity())
    
    // Test removing elements from various positions
    first_removed<Int> = large.remove_at(0)    // Remove first
    last_removed<Int> = large.remove_at(large.len() - 1)  // Remove last
    middle_removed<Int> = large.remove_at(large.len() / 2)  // Remove middle
    
    println("Removed first:", first_removed)
    println("Removed last:", last_removed) 
    println("Removed middle:", middle_removed)
    println("New length after removals:", large.len())
    
    // Test array conversion edge cases
    small_conversion<[Int; 2]> = large.to_array(2)  // Convert large Vec to small array
    large_conversion<[Int; 200]> = large.to_array(200)  // Convert to larger array than Vec size
    
    // Test concat with empty Vec
    empty2<Vec<Int>> = Vec::new()
    combined<Vec<Int>> = large.concat(empty2)
    println("Combined with empty length:", combined.len())
    
    combined2<Vec<Int>> = empty2.concat(large)
    println("Empty combined with large length:", combined2.len())
    
    // Test clear on already empty Vec
    empty.clear()
    println("Clear on empty - length:", empty.len())
    
    return 0;
}