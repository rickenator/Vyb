// Test Vec type checking and error handling
main()<Int> -> {
    // Test proper type enforcement
    int_vec<Vec<Int>> = Vec::new()

    // These should work - correct types
    int_vec.push(42)
    int_vec.push(100)

    // Test with different element types
    string_vec<Vec<String>> = Vec::new()
    string_vec.push("hello")
    string_vec.push("world")

    // Test array compatibility
    int_array<[Int; 3]> = [1, 2, 3]
    int_vec.push_array(int_array)  // Should work - compatible types

    // Test method parameter validation
    // These should trigger semantic errors:
    // int_vec.push()              // Missing argument
    // int_vec.push(1, 2)          // Too many arguments
    // int_vec.pop(42)             // Pop takes no arguments
    // int_vec.len(100)            // Len takes no arguments
    // int_vec.get()               // Get needs index argument
    // int_vec.get(1, 2)           // Get takes only one argument

    // Test return type usage
    length<Int> = int_vec.len()
    is_empty<Bool> = int_vec.is_empty()
    capacity<Int> = int_vec.capacity()
    contains_42<Bool> = int_vec.contains(42)

    // Test chaining return types
    chained<Vec<Int>> = int_vec.push(999).push(888)

    // Test array conversion
    converted<[Int; 5]> = int_vec.to_array(5)

    println("Type checking test completed successfully")
    return 0;
}