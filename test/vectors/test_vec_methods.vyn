main()<Int> -> {
    // Test Vec with different types
    words<Vec<String>> = Vec::new();
    words.push("hello");
    words.push("world");
    
    empty<Vec<Int>> = Vec::new();
    println("Length:", empty.len());
    
    empty.push(42);
    println("After push:", empty.len());
    println("Contents:", empty);
    
    return 0;
}