// Test new Int32 and Float32 types

main()<Int> -> {
    // Test Int32 type
    small_int<Int32> = 42;
    large_int<Int> = 9223372036854775807;  // Max Int64
    
    println("Int32 value:", small_int);
    println("Int64 value:", large_int);
    
    // Test Float32 type
    small_float<Float32> = 3.14;
    large_float<Float> = 3.141592653589793;  // Higher precision Float64
    
    println("Float32 value:", small_float);
    println("Float64 value:", large_float);
    
    // Test Vec with different numeric types
    int32_vec<Vec<Int32>> = Vec::new(3);
    float32_vec<Vec<Float32>> = Vec::new(2);
    
    // These should be zero-initialized
    int32_first<Int32> = int32_vec.get(0);
    float32_first<Float32> = float32_vec.get(0);
    
    println("Int32 Vec first element (should be 0):", int32_first);
    println("Float32 Vec first element (should be 0.0):", float32_first);
    
    return 0;
}