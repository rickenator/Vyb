// Test Vec array integration - push_array and to_array
main()<Int> -> {
    // Test push_array functionality
    vec<Vec<Int>> = Vec::new();
    
    // Create an array to push
    arr<[Int; 3]> = [10, 20, 30];
    
    // Push entire array to Vec
    vec.push_array(arr);
    println("After push_array:");
    println("Vec length:", vec.len());
    println("Vec contents:", vec);
    
    // Add more individual elements
    vec.push(40).push(50);
    println("After adding more elements:");
    println("Vec length:", vec.len());
    
    // Test to_array functionality (allocates new array)
    output_array<[Int; 5]> = vec.to_array(5);
    println("Converted to array:", output_array);
    
    // Test with different array sizes
    small_array<[Int; 3]> = vec.to_array(3);  // Should take first 3 elements
    println("Small array (first 3):", small_array);
    
    // Test get_array functionality (efficient - uses pre-allocated array)
    println("Testing efficient get_array method:");
    pre_allocated<[Int; 5]> = [0, 0, 0, 0, 0];
    copied_count<Int> = vec.get_array(pre_allocated);
    println("Copied", copied_count, "elements to pre-allocated array");
    println("Pre-allocated array now contains:", pre_allocated);
    
    // Test with smaller pre-allocated buffer
    small_buffer<[Int; 3]> = [99, 99, 99];  // Pre-filled to show partial copy
    copied_small<Int> = vec.get_array(small_buffer);
    println("Copied", copied_small, "elements to small buffer");
    println("Small buffer contents:", small_buffer);
    
    // Test type compatibility between Vec<T> and [T; N]
    string_vec<Vec<String>> = Vec::new();
    string_arr<[String; 2]> = ["hello", "world"];
    string_vec.push_array(string_arr);
    println("String vec length:", string_vec.len());
    
    return 0;
}