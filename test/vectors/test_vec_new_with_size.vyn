// Test Vec::new() and Vec::new(size) constructors with reference model semantics
// This test also verifies Int32 and Float32 type support

main()<Int> -> {
    // Test Vec::new() - empty vector (existing functionality)
    empty_vec<Vec<Int>> = Vec::new();
    empty_vec.push(42);
    println("Empty Vec created and element pushed");
    
    // Test Vec::new(size) - preallocated vector with zero-initialized elements
    preallocated_vec<Vec<Int>> = Vec::new(5);
    println("Preallocated Vec created with size 5");
    
    // In reference model: numeric elements are zero-initialized
    // The Vec should contain [0, 0, 0, 0, 0]
    first_element<Int> = preallocated_vec.get(0);
    println("First element verified (should be 0)");
    
    // Test with different sizes
    small_vec<Vec<Int>> = Vec::new(2);
    large_vec<Vec<Int>> = Vec::new(10);
    println("Different sized Vecs created");
    
    // Test modifying preallocated Vec
    preallocated_vec.push(100);  // Should append to end
    println("Element pushed to preallocated Vec");
    
    return 0;
}