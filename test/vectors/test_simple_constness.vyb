// Simple test to verify constness checking works for Vec methods

main()<Int> -> {
    // Test with mutable Vec - should work
    mutable_vec<Vec<Int>> = Vec::new();
    mutable_vec.push(1);
    mutable_vec.push(2);
    len1<Int> = mutable_vec.len();

    println("Mutable Vec operations work - length:", len1);

    // Note: To properly test const Vec, we need semantic analysis to catch the error
    // during compilation, not runtime. The current test shows non-const operations work.

    return 0;
}