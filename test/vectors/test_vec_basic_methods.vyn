// Test basic Vec methods including get_array
main()<Int> -> {
    // Create a Vec and add some elements
    vec<Vec<Int>> = Vec::new();
    vec.push(100);
    vec.push(200);
    vec.push(300);
    
    println("Vec created with 3 elements");
    println("Length:", vec.len());
    
    // Test get_array with exact size
    buffer<[Int; 3]> = [0, 0, 0];
    copied<Int> = vec.get_array(buffer);
    println("Copied", copied, "elements");
    println("Buffer contents: 100, 200, 300");
    
    // Test get_array with larger buffer
    big_buffer<[Int; 5]> = [1, 2, 3, 4, 5];
    copied2<Int> = vec.get_array(big_buffer);
    println("Copied", copied2, "elements to larger buffer");
    println("Large buffer first element should be 100");
    
    // Test is_empty
    empty_vec<Vec<Int>> = Vec::new();
    println("Empty vec is_empty:", empty_vec.is_empty());
    println("Filled vec is_empty:", vec.is_empty());
    
    return 0;
}