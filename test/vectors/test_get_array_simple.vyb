// Test: Basic get_array functionality - simple test without method chaining
main()<Int> -> {
    // Create and initialize Vec
    vec<Vec<Int>> = Vec::new();
    vec.push(10);
    vec.push(20);
    vec.push(30);
    println("Vec populated with 3 elements");

    // Test get_array with exact size buffer
    buffer<[Int; 3]> = [0, 0, 0];
    copied<Int> = vec.get_array(buffer);
    println("Copied elements:");
    println(copied);

    return 0;
}