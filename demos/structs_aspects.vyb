// Demo: structs, aspects, bind, and method dispatch.

aspect Greet {
    greet(self)<Void>
}

struct Person {
    name<String>
}

bind Greet -> Person {
    greet(self)<Void> -> {
        print("hello ")
        println(self.name)
    }
}

main()<Int> -> {
    p<Person> = Person { name = "VyB" }
    p.greet()
    return 0
}
